def ts():
    """Current timestamp string."""
    return datetime.datetime.now().strftime("%H:%M:%S %d.%m.%Y")

# ─── VERSION & UPDATE LOG ────────────────────────────────────────────────────

def fetch_url(url, timeout=6):
    """Fetch a URL and return text or None on error."""
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "wanwat/1.0"})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.read().decode("utf-8").strip()
    except Exception as e:
        return None

def get_remote_version():
    return fetch_url(VER_URL)

def get_remote_updlog():
    return fetch_url(UPDLOG_URL)

def ensure_logs_dir():
    d = os.path.dirname(LOGS_CACHE_PATH)
    os.makedirs(d, exist_ok=True)

def load_cached_logs():
    if os.path.exists(LOGS_CACHE_PATH):
        try:
            with open(LOGS_CACHE_PATH) as f:
                return json.load(f)
        except Exception:
            pass
    return {}

def save_cached_logs(data):
    ensure_logs_dir()
    with open(LOGS_CACHE_PATH, "w") as f:
        json.dump(data, f, indent=2)

def version_outdated(remote):
    """Simple string compare — not up to date if they differ."""
    if remote is None:
        return False
    return remote.strip() != LOCAL_VERSION.strip()

