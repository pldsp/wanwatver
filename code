# ─── INSTALL LOGIC ───────────────────────────────────────────────────────────

def confirm_install(deps):
    pv_str    = python_version_str()
    already   = [d for d in deps if is_installed(d)]
    to_install = [d for d in deps if not is_installed(d)]

    incompatible = []
    partial      = []
    for d in to_install:
        status, note = check_compat(d)
        if status == "unsupported":
            incompatible.append((d, note))
        elif status == "partial":
            partial.append((d, note))

    sep()
    print(f"\n{BOLD}{YELLOW}  ⚠  Installation Confirmation{R}\n")

    if already:
        print(f"  {GREEN}✓ Already installed — skipping ({len(already)}):{R}")
        for pkg in already:
            ver = get_installed_version(pkg)
            print(f"    {DIM}• {pkg}  {ver}{R}")
        print()

    if not to_install:
        print(f"  {GREEN}{BOLD}All selected packages are already installed!{R}\n")
        input(f"  {DIM}Press Enter to continue...{R}")
        return False, []

    print(f"  Will install  {CYAN}{BOLD}{len(to_install)}{R} package(s)")
    print(f"  Python version  {GREEN}{BOLD}{pv_str}{R}\n")

    if incompatible:
        print(f"  {RED}{BOLD}✗ Incompatible with Python {pv_str}:{R}")
        for pkg, note in incompatible:
            print(f"    {RED}• {pkg:<28}{R} {DIM}{note}{R}")
        print()

    if partial:
        print(f"  {YELLOW}{BOLD}~ Partially supported on Python {pv_str}:{R}")
        for pkg, note in partial:
            print(f"    {YELLOW}• {pkg:<28}{R} {DIM}{note}{R}")
        print()

    if not incompatible and not partial:
        print(f"  {GREEN}✓ All packages appear compatible.{R}\n")

    print(f"  {DIM}Tip: press Ctrl+C during install to cancel safely.{R}\n")
    print(f"  {BOLD}Continue?{R}  {DIM}[y/N]{R}  ", end="")
    ans = input().strip().lower()
    return ans in ("y", "yes"), to_install


def install_deps(deps, dev_mode=False):
    global _serious_mode
    if not deps:
        print(f"\n  {YELLOW}No packages selected.{R}\n")
        return []

    confirmed, to_install = confirm_install(deps)
    if not confirmed or not to_install:
        if confirmed and not to_install:
            pass
        else:
            print(f"\n  {YELLOW}Installation cancelled.{R}\n")
        return []

    print(f"\n  {CYAN}{BOLD}Installing {len(to_install)} package(s)...{R}")
    print(f"  {DIM}Ctrl+C = cancel at any time{R}\n")
    sep()

    ok, failed, skipped = [], [], []
    cancelled = False

    for i, pkg in enumerate(to_install, 1):
        pct     = int((i / len(to_install)) * 100)
        blen    = 26
        filled  = int(blen * i // len(to_install))
        bar     = f"{GREEN}{'█' * filled}{DIM}{'░' * (blen - filled)}{R}"
        print(f"  [{bar}] {pct:3d}%  {CYAN}{pkg:<30}{R}  {DIM}({i}/{len(to_install)}){R}", flush=True)

        if is_installed(pkg):
            skipped.append(pkg)
            print(f"         {DIM}↷ already installed, skipping{R}")
            serious_log(f"SKIP {pkg} — already installed")
            continue

        cmd = [sys.executable, "-m", "pip", "install", pkg,
               "--quiet", "--disable-pip-version-check"]
        serious_log(f"CMD  {' '.join(cmd)}")

        try:
            proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                    stderr=subprocess.PIPE, text=True)
            try:
                stdout, stderr = proc.communicate(timeout=120)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.communicate()
                raise TimeoutError(f"timed out after 120s")

            serious_log(f"RC   {proc.returncode}")
            if stderr.strip():
                serious_log(f"STDERR >> {stderr.strip()[:200]}")

            if proc.returncode == 0:
                ok.append(pkg)
                print(f"         {GREEN}✓ installed{R}")
            else:
                err_lines = [l.strip() for l in stderr.splitlines() if l.strip()]
                err_msg = next(
                    (l for l in reversed(err_lines) if l.lower().startswith("error")),
                    err_lines[-1] if err_lines else "unknown error"
                )
                failed.append((pkg, err_msg))
                print(f"         {RED}✗ failed  {DIM}{err_msg[:68]}{R}")
                serious_log(f"FAIL {pkg} — {err_msg}")

                print(f"\n  {YELLOW}'{pkg}' failed.{R}  Continue?  {DIM}[Y/n]{R}  ", end="")
                try:
                    ans = input().strip().lower()
                except (EOFError, KeyboardInterrupt):
                    cancelled = True; break
                if ans in ("n", "no"):
                    cancelled = True
                    print(f"\n  {YELLOW}Stopping at user request.{R}")
                    break
                print()

        except TimeoutError as e:
            failed.append((pkg, str(e)))
            print(f"         {RED}✗ {e}{R}")
            serious_log(f"TIMEOUT {pkg}")
            print(f"\n  {YELLOW}'{pkg}' timed out.{R}  Continue?  {DIM}[Y/n]{R}  ", end="")
            try:
                ans = input().strip().lower()
            except (EOFError, KeyboardInterrupt):
                cancelled = True; break
            if ans in ("n", "no"):
                cancelled = True; break
            print()

        except KeyboardInterrupt:
            print(f"\n\n  {YELLOW}{BOLD}⚠  Cancelled by user (Ctrl+C){R}")
            serious_log("INTERRUPTED by KeyboardInterrupt")
            cancelled = True
            break

        except Exception as e:
            failed.append((pkg, str(e)))
            print(f"         {RED}✗ {str(e)[:68]}{R}")
            serious_log(f"EXCEPTION {pkg} — {e}")
            print(f"\n  {YELLOW}Error on '{pkg}'.{R}  Continue?  {DIM}[Y/n]{R}  ", end="")
            try:
                ans = input().strip().lower()
            except (EOFError, KeyboardInterrupt):
                cancelled = True; break
            if ans in ("n", "no"):
                cancelled = True; break
            print()

    print()
    sep()

    remaining = len(to_install) - len(ok) - len(failed) - len(skipped)
    if cancelled and remaining > 0:
        print(f"\n  {YELLOW}⚠  Cancelled  —  {remaining} package(s) not attempted{R}\n")

    print(f"  {GREEN}{BOLD}✓ Installed: {len(ok):<4}{R}"
          f"  {YELLOW}{BOLD}↷ Skipped: {len(skipped):<4}{R}"
          f"  {RED}{BOLD}✗ Failed: {len(failed)}{R}\n")

    if skipped:
        print(f"  {DIM}Skipped: {', '.join(skipped)}{R}\n")

    if failed:
        print(f"  {RED}Failed packages:{R}")
        for pkg, err in failed:
            print(f"    {RED}• {pkg:<28}{R} {DIM}{err[:68]}{R}")
        print()

    return ok

