# ─── HELPERS ─────────────────────────────────────────────────────────────────

def clear():
    os.system("cls" if os.name == "nt" else "clear")

def python_version():
    return sys.version_info

def python_version_str():
    v = sys.version_info
    return f"{v.major}.{v.minor}.{v.micro}"

def is_installed(pkg):
    try:
        importlib.metadata.version(pkg)
        return True
    except importlib.metadata.PackageNotFoundError:
        return False

def get_installed_version(pkg):
    try:
        return importlib.metadata.version(pkg)
    except Exception:
        return None

def check_compat(pkg):
    pv   = python_version()
    info = COMPAT.get(pkg)
    if not info:
        return ("ok", "")
    mn, mx, note = info["min"], info["max"], info["note"]
    if pv < mn:
        return ("unsupported", f"Requires Python {mn[0]}.{mn[1]}+. {note}".strip())
    if mx and pv > mx:
        return ("partial", f"Tested up to {mx[0]}.{mx[1]}. {note}".strip())
    return ("ok", note if note else "")

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH) as f:
                return json.load(f)
        except:
            pass
    return {"selected": [], "installed": [], "dev_mode": False}

def save_config(cfg):
    cfg.pop("serious_mode", None)
    with open(CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2)

def all_deps():
    deps = []
    for pk in WANPACKS.values():
        for d in pk["deps"]:
            if d not in deps:
                deps.append(d)
    return deps

def sep(char="─", color=DIM):
    w = shutil.get_terminal_size((80, 20)).columns
    print(f"{color}{char * w}{R}")

def ts():
    return datetime.datetime.now().strftime("%H:%M:%S %d.%m.%Y")

def fetch_url(url, timeout=6):
    try:
        # Add random query param to bust cache
        url_with_bust = f"{url}?t={int(time.time())}"
        req = urllib.request.Request(url_with_bust, headers={"User-Agent": "wanwat/1.1"})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.read().decode("utf-8").strip()
    except:
        return None

def get_remote_version():
    return fetch_url(VER_URL)

def get_remote_updlog():
    return fetch_url(UPDLOG_URL)

def version_outdated(remote):
    if remote is None: return False
    return remote.strip() != LOCAL_VERSION.strip()

