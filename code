def python_version():
    return sys.version_info

def python_version_str():
    v = sys.version_info
    return f"{v.major}.{v.minor}.{v.micro}"

def is_installed(pkg):
    try:
        importlib.metadata.version(pkg)
        return True
    except importlib.metadata.PackageNotFoundError:
        return False

def get_installed_version(pkg):
    try:
        return importlib.metadata.version(pkg)
    except:
        return None

def check_compat(pkg):
    pv   = python_version()
    info = COMPAT.get(pkg)
    if not info:
        return ("ok", "")
    mn, mx, note = info["min"], info["max"], info["note"]
    if pv < mn:
        return ("unsupported", f"Requires Python {mn[0]}.{mn[1]}+. {note}".strip())
    if mx and pv > mx:
        return ("partial", f"Tested up to {mx[0]}.{mx[1]}. {note}".strip())
    return ("ok", note if note else "")

