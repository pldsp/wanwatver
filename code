def install_deps(to_install):
    if not to_install: return []
    print(f"\n  {CYAN}{BOLD}Installing {len(to_install)} package(s)...{R}")
    sep()
    ok = []
    for i, pkg in enumerate(to_install, 1):
        pct = int((i / len(to_install)) * 100)
        filled = int(26 * i // len(to_install))
        bar = f"{GREEN}{'█' * filled}{DIM}{'░' * (26 - filled)}{R}"
        print(f"  [{bar}] {pct:3d}%  {CYAN}{pkg:<30}{R}  {DIM}({i}/{len(to_install)}){R}", flush=True)
        if is_installed(pkg):
            print(f"         {DIM}↷ already installed, skipping{R}")
            continue
        cmd = [sys.executable, "-m", "pip", "install", pkg, "--quiet", "--disable-pip-version-check"]
        serious_log(f"CMD {' '.join(cmd)}")
        try:
            proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            stdout, stderr = proc.communicate(timeout=180)
            if proc.returncode == 0:
                ok.append(pkg)
                print(f"         {GREEN}✓ installed{R}")
            else:
                print(f"         {RED}✗ failed{R}")
                serious_log(f"FAIL {pkg} // {stderr.strip()}")
        except Exception as e:
            print(f"         {RED}✗ {e}{R}")
    return ok

