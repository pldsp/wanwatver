# ─── AUTO UPDATE LOGIC ───────────────────────────────────────────────────────

def run_auto_update():
    clear()
    print(f"\n{CYAN}{BOLD}  wanwat  ·  Update Sequence{R}")
    sep()
    print(f"\n  {BOLD}1.{R}  Downloading new code from GitHub...")
    new_code = fetch_url(CODE_URL, timeout=15)
    
    if not new_code:
        print(f"  {RED}✗ Failed to download update. Check connection.{R}")
        time.sleep(2)
        return

    current_file = os.path.abspath(sys.argv[0])
    current_dir = os.path.dirname(current_file)
    temp_file = os.path.join(current_dir, "temp.py")
    handler_file = os.path.join(current_dir, "handler.py")

    print(f"  {BOLD}2.{R}  Creating temporary files...")
    try:
        with open(temp_file, "w", encoding="utf-8") as f:
            f.write(new_code)
        
        # Create handler script to manage the replacement
        handler_code = f"""
import os
import sys
import time
import subprocess

# Wait for main process to close
time.sleep(1)

original = {repr(current_file)}
temp = {repr(temp_file)}
handler = {repr(handler_file)}

try:
    if os.path.exists(original):
        os.remove(original)
    os.rename(temp, original)
    print("Update complete. Restarting...")
    subprocess.Popen([sys.executable, original])
except Exception as e:
    print(f"Update failed: {{e}}")
    if os.path.exists(temp):
        os.remove(temp)
finally:
    # Handler deletes itself after spawning the new process
    # Note: On Windows, we can't delete the running script easily, 
    # but the new wanwat will delete handler.py on startup.
    pass
"""
        with open(handler_file, "w", encoding="utf-8") as f:
            f.write(handler_code)
            
        print(f"  {BOLD}3.{R}  Launching update handler...")
        subprocess.Popen([sys.executable, handler_file])
        print(f"\n  {GREEN}Update ready. Closing current instance...{R}")
        time.sleep(1)
        sys.exit(0)
    except Exception as e:
        print(f"  {RED}✗ Local IO Error: {e}{R}")
        time.sleep(2)

def cleanup_update():
    # Called on startup to remove the handler file
    current_file = os.path.abspath(sys.argv[0])
    current_dir = os.path.dirname(current_file)
    handler_file = os.path.join(current_dir, "handler.py")
    if os.path.exists(handler_file):
        try:
            os.remove(handler_file)
            serious_log("Cleaned up update handler.")
        except:
            pass

# ─── INSTALL LOGIC ───────────────────────────────────────────────────────────

def install_deps(to_install, dev_mode=False):
    if not to_install:
        return []

    print(f"\n  {CYAN}{BOLD}Installing {len(to_install)} package(s)...{R}")
    sep()

    ok, failed, skipped = [], [], []
    cancelled = False

    for i, pkg in enumerate(to_install, 1):
        pct     = int((i / len(to_install)) * 100)
        blen    = 26
        filled  = int(blen * i // len(to_install))
        bar     = f"{GREEN}{'█' * filled}{DIM}{'░' * (blen - filled)}{R}"
        print(f"  [{bar}] {pct:3d}%  {CYAN}{pkg:<30}{R}  {DIM}({i}/{len(to_install)}){R}", flush=True)

        if is_installed(pkg):
            skipped.append(pkg)
            print(f"         {DIM}↷ already installed, skipping{R}")
            serious_log(f"SKIP {pkg}")
            continue

        cmd = [sys.executable, "-m", "pip", "install", pkg, "--quiet", "--disable-pip-version-check"]
        serious_log(f"CMD  {' '.join(cmd)}")

        try:
            proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            stdout, stderr = proc.communicate(timeout=120)
            if proc.returncode == 0:
                ok.append(pkg)
                print(f"         {GREEN}✓ installed{R}")
            else:
                failed.append((pkg, stderr.strip() or "unknown error"))
                print(f"         {RED}✗ failed{R}")
        except Exception as e:
            failed.append((pkg, str(e)))
            print(f"         {RED}✗ {e}{R}")

    return ok

