def dev_info():
    info = {}
    info["python"]    = sys.version
    info["platform"]  = platform.platform()
    info["system"]    = platform.system()
    info["node"]      = platform.node()
    info["release"]   = platform.release()
    info["machine"]   = platform.machine()
    info["processor"] = platform.processor()
    info["arch"]      = platform.architecture()[0]
    info["bits"]      = struct.calcsize("P") * 8
    info["cpu_count"] = os.cpu_count()
    info["exe"]       = sys.executable
    info["prefix"]    = sys.prefix
    try:
        import psutil
        mem = psutil.virtual_memory()
        info["ram_total"] = f"{mem.total // (1024**3)} GB"
        info["ram_used"]  = f"{mem.used  // (1024**3)} GB"
        info["ram_pct"]   = f"{mem.percent}%"
        disk = psutil.disk_usage("/" if os.name != "nt" else "C:\\")
        info["disk_total"] = f"{disk.total // (1024**3)} GB"
        info["disk_used"]  = f"{disk.used  // (1024**3)} GB"
    except ImportError:
        info["ram_total"] = "install psutil for RAM/disk info"
    return info

