def banner(cfg, remote_ver):
    print(f"\n{CYAN}{BOLD}  WANWAT {R} {DIM}v{LOCAL_VERSION}{R}")
    if version_outdated(remote_ver):
        print(f"  {YELLOW}⚠ UPDATE AVAILABLE: {remote_ver} (type 'update' to install){R}")
    sep()

def main_menu():
    global _serious_mode
    cfg = load_config()
    cleanup_update()
    
    remote_ver = get_remote_version()

    while True:
        if cfg.get("dev_mode"):
            if not developer_mode_menu(cfg):
                cfg["dev_mode"] = False
            continue

        clear()
        banner(cfg, remote_ver)
        
        sm_tag = f" {ghost_raw('[SERIOUS]')}" if _serious_mode else ""
        print(f"  {BOLD}SYSTEM_COMMANDS{R}{sm_tag}\n")
        
        cmds = [
            ("installdeps", "Install selected packages"),
            ("deps",        "Manage package lists"),
            ("update",      "Auto-update wanwat"),
            ("devmode",     "Enter developer shell"),
            ("quit",        "Exit application")
        ]
        
        for c, d in cmds:
            print(f"  {CYAN}{c:<15}{R} {DIM}» {d}{R}")
            
        print(f"\n  {DIM}wanwat>{R} ", end="")
        cmd = input().strip().lower()

        if cmd == "serious":
            _serious_mode = not _serious_mode
            if _serious_mode: serious_banner()
            time.sleep(1)
        elif cmd == "update":
            run_auto_update()
        elif cmd == "devmode":
            cfg["dev_mode"] = True
            save_config(cfg)
        elif cmd == "installdeps":
            install_deps(cfg.get("selected", all_deps()))
            input("\n  Press Enter...")
        elif cmd == "quit":
            sys.exit(0)

if __name__ == "__main__":
    main_menu()
