def main_menu():
    global _serious_mode
    cfg        = load_config()
    dev_mode   = cfg.get("dev_mode", False)
    remote_ver = get_remote_version()   # non-blocking enough for menu use

    if dev_mode:
        while developer_mode_menu(cfg):
            clear()
        dev_mode = False

    while True:
        clear()
        banner(cfg, remote_ver)

        dm_tag = f"  {BLUE}[DEV]{R}" if dev_mode else ""
        sm_tag = f"  {ghost_raw('[serious]')}" if _serious_mode else ""

        print(f"\n  {BOLD}Commands{R}{dm_tag}{sm_tag}\n")
        sep("·")

        # Two-column layout
        cmds = [
            (f"{CYAN}installdeps{R}",   "Install selected dependencies"),
            (f"{CYAN}deps{R}",          "Manage packages & wanpacks"),
            (f"{CYAN}updatelogs{R}",    "View update logs from GitHub"),
            (f"{CYAN}developermode{R}", "Developer debug mode"),
            (f"{CYAN}quit{R}",          "Exit wanwat"),
        ]
        for cmd_text, desc in cmds:
            print(f"  {cmd_text:<30}  {DIM}{desc}{R}")

        # Newest log teaser
        cache = load_cached_logs()
        if cache:
            latest_ver = list(cache.keys())[-1]
            latest_entry = cache[latest_ver]
            latest_lines = latest_entry.get("log","").splitlines()
            teaser = latest_lines[0][:60] if latest_lines else ""
            print(f"\n  {DIM}────  newest log  ·  {latest_ver}  ────{R}")
            print(f"  {DIM}{teaser}{'…' if len(teaser) == 60 else ''}{R}")

        print()
        sep()

        if dev_mode:
            print(f"\n  {BLUE}{datetime.datetime.now().strftime('%H:%M:%S')}{R}  {DIM}debug active{R}")

        print(f"\n  {DIM}wanwat>{R} ", end="")
        cmd = input().strip().lower()

        # ── secret trigger ──────────────────────────────────────────────────
        if cmd == "serious":
            _serious_mode = not _serious_mode
            if _serious_mode:
                serious_banner()
                time.sleep(1.2)
            continue

        if cmd == "installdeps":
            selected = cfg.get("selected", all_deps())
            if not selected:
                selected = all_deps()
            serious_log(f"INSTALLDEPS called — {len(selected)} packages queued")
            installed_ok = install_deps(selected, dev_mode)
            if installed_ok:
                cfg["installed"] = list(set(cfg.get("installed", []) + installed_ok))
                save_config(cfg)
            input(f"\n  {DIM}Press Enter...{R}")

        elif cmd == "deps":
            serious_log("ENTERING deps menu")
            deps_menu(cfg, dev_mode, remote_ver)

        elif cmd == "updatelogs":
            serious_log("ENTERING update logs menu")
            update_logs_menu()

        elif cmd == "developermode":
            cfg["dev_mode"] = True
            save_config(cfg)
            clear()
            while developer_mode_menu(cfg):
                clear()
            dev_mode = False

        elif cmd in ("quit", "exit", "q"):
            clear()
            print(f"\n  {CYAN}Thanks for using wanwat. Goodbye!{R}\n")
            sys.exit(0)

        else:
            print(f"\n  {YELLOW}Unknown command.{R}  {DIM}Try: installdeps, deps, updatelogs, developermode, quit{R}")
            time.sleep(1.2)

