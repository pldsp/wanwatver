def run_auto_update():
    clear()
    print(f"\n{CYAN}{BOLD}  wanwat  ·  Update Sequence{R}")
    sep()
    print(f"\n  1.  Downloading new code from GitHub...")
    new_code = fetch_url(CODE_URL, timeout=15)
    
    if not new_code:
        print(f"  ✗ Failed to download update. Check connection.")
        time.sleep(2)
        return

    current_file = os.path.abspath(sys.argv[0])
    current_dir = os.path.dirname(current_file)
    temp_file = os.path.join(current_dir, "temp.py")
    handler_file = os.path.join(current_dir, "handler.py")

    print(f"  2.  Creating temporary files...")
    try:
        with open(temp_file, "w", encoding="utf-8") as f:
            f.write(new_code)
        
        handler_code = f"""
import os
import sys
import time
import subprocess

time.sleep(2)

original = {repr(current_file)}
temp = {repr(temp_file)}
handler = {repr(handler_file)}

try:
    if os.path.exists(original):
        os.remove(original)
    os.rename(temp, original)
    print("Update complete. Restarting...")
    
    if os.name == 'nt':
        subprocess.Popen([sys.executable, original], creationflags=0x00000010, close_fds=True)
    else:
        subprocess.Popen([sys.executable, original], preexec_fn=os.setpgrp, close_fds=True)
        
except Exception as e:
    print(f"Update failed: {{e}}")
sys.exit(0)
"""
        with open(handler_file, "w", encoding="utf-8") as f:
            f.write(handler_code)
            
        print(f"  3.  Launching update handler...")
        if os.name == 'nt':
            subprocess.Popen([sys.executable, handler_file], creationflags=0x00000010)
        else:
            subprocess.Popen([sys.executable, handler_file], preexec_fn=os.setpgrp)
            
        print(f"\n  Update ready. Closing instance...")
        time.sleep(1)
        sys.exit(0)
    except Exception as e:
        print(f"  ✗ Local IO Error: {e}")
        time.sleep(2)

def cleanup_update():
    current_file = os.path.abspath(sys.argv[0])
    current_dir = os.path.dirname(current_file)
    handler_file = os.path.join(current_dir, "handler.py")
    temp_file = os.path.join(current_dir, "temp.py")
    for f in [handler_file, temp_file]:
        if os.path.exists(f):
            try: os.remove(f)
            except: pass

