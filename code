def toggle_packages(cfg, dev_mode=False):
    all_pkgs  = all_deps()
    selected  = set(cfg.get("selected", all_pkgs))
    page_size = 18
    page      = 0
    total_pages = (len(all_pkgs) + page_size - 1) // page_size

    while True:
        clear()
        print(f"\n{CYAN}{BOLD}  wanwat{R}  {DIM}Toggle Packages  (page {page+1}/{total_pages}){R}\n")
        sep()

        start = page * page_size
        chunk = all_pkgs[start:start + page_size]

        for i, pkg in enumerate(chunk, 1):
            tick        = f"{GREEN}✓{R}" if pkg in selected else f"{DIM}·{R}"
            compat, _   = check_compat(pkg)
            tag = ""
            if compat == "unsupported":
                tag = f" {RED}[!]{R}"
            elif compat == "partial":
                tag = f" {YELLOW}[~]{R}"
            inst = f"  {DIM}installed{R}" if is_installed(pkg) else ""
            print(f"  {DIM}{i:2}.{R} [{tick}] {CYAN}{pkg}{R}{tag}{inst}")

        sel_count = len(selected)
        print(f"\n  {DIM}selected: {sel_count}  ·  [n]ext  [p]rev  [#] toggle  [a]ll  [x] none  [q] back{R}\n")
        sep()
        print(f"\n  {DIM}toggle>{R} ", end="")
        inp = input().strip().lower()

        if inp == "q":
            break
        elif inp == "n" and page < total_pages - 1:
            page += 1
        elif inp == "p" and page > 0:
            page -= 1
        elif inp == "a":
            selected = set(all_pkgs)
        elif inp == "x":
            selected = set()
        elif inp.isdigit():
            idx = int(inp) - 1
            if 0 <= idx < len(chunk):
                pkg = chunk[idx]
                if pkg in selected:
                    selected.discard(pkg)
                else:
                    selected.add(pkg)

    cfg["selected"] = list(selected)
    save_config(cfg)

def choose_wanpack(cfg, dev_mode=False):
    while True:
        clear()
        print(f"\n{CYAN}{BOLD}  wanwat{R}  {DIM}Wanpacks{R}\n")
        sep()
        names = list(WANPACKS.keys())
        for i, name in enumerate(names, 1):
            desc  = WANPACKS[name]["description"]
            count = len(WANPACKS[name]["deps"])
            inst  = sum(1 for d in WANPACKS[name]["deps"] if is_installed(d))
            pct   = int(inst / count * 100) if count else 0
            bar   = f"{GREEN}{'▪' * (pct // 10)}{DIM}{'▫' * (10 - pct // 10)}{R}"
            print(f"\n  {BOLD}{i}.{R}  {CYAN}{name}{R}  {DIM}{inst}/{count} installed{R}  [{bar}]")
            print(f"      {DIM}{desc}{R}")

        print(f"\n  {BOLD}{len(names)+1}.{R}  Install ALL wanpacks\n")
        sep()
        print(f"  {DIM}[q] back{R}\n")
        print(f"  {DIM}wanpack>{R} ", end="")
        inp = input().strip().lower()

        if inp == "q":
            break
        elif inp.isdigit():
            idx = int(inp) - 1
            if idx == len(names):
                deps = list({d for pk in WANPACKS.values() for d in pk["deps"]})
                installed_ok = install_deps(deps, dev_mode)
                if installed_ok:
                    cfg["installed"] = list(set(cfg.get("installed", []) + installed_ok))
                    save_config(cfg)
                input(f"\n  {DIM}Press Enter...{R}")
            elif 0 <= idx < len(names):
                name = names[idx]
                deps = WANPACKS[name]["deps"]
                clear()
                print(f"\n{CYAN}{BOLD}  {name}{R}  — {DIM}{WANPACKS[name]['description']}{R}\n")
                sep()
                for d in deps:
                    compat, note = check_compat(d)
                    tag = ""
                    if compat == "unsupported":
                        tag = f"  {RED}[incompatible]{R}"
                    elif compat == "partial":
                        tag = f"  {YELLOW}[partial]{R}"
                    inst = f"  {GREEN}installed{R}" if is_installed(d) else ""
                    print(f"  {DIM}•{R}  {d}{tag}{inst}")
                print()
                installed_ok = install_deps(deps, dev_mode)
                if installed_ok:
                    cfg["installed"] = list(set(cfg.get("installed", []) + installed_ok))
                    save_config(cfg)
                input(f"\n  {DIM}Press Enter...{R}")

